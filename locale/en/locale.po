# ── Plugin metadata ──────────────────────────────────────────────────────────
msgid "plugins.generic.magicLogin.displayName"
msgstr "Passwordless Sign-in (Magic Link)"

msgid "plugins.generic.magicLogin.description"
msgstr "Lets users sign in with a one-time link emailed to them, alongside the normal password login. Requires no changes to core OJS files."

# ── Settings form ─────────────────────────────────────────────────────────────
msgid "plugins.generic.magicLogin.settings.enabled"
msgstr "Enable magic-link sign-in for this journal"

msgid "plugins.generic.magicLogin.settings.ttl"
msgstr "Link validity (minutes)"

msgid "plugins.generic.magicLogin.settings.ttl.description"
msgstr "How long a link remains usable after it is issued. Minimum 1, maximum 120. Default: 15."

msgid "plugins.generic.magicLogin.settings.minInterval"
msgstr "Minimum seconds between requests per account"

msgid "plugins.generic.magicLogin.settings.minInterval.description"
msgstr "Prevents a single account from flooding itself with links. Minimum 30, maximum 3600. Default: 60."

# ── Shared / chrome strings ───────────────────────────────────────────────────
msgid "plugins.generic.magicLogin.shared.secureConnection"
msgstr "Secure connection"

msgid "plugins.generic.magicLogin.shared.memberAccess"
msgstr "Member access"

msgid "plugins.generic.magicLogin.shared.builtOn"
msgstr "Powered by OJS"

# ── Request page (GET /magicLogin/request) ────────────────────────────────────
msgid "plugins.generic.magicLogin.request.title"
msgstr "Sign in with a magic link"

msgid "plugins.generic.magicLogin.request.section"
msgstr "Passwordless sign-in"

msgid "plugins.generic.magicLogin.request.heading"
msgstr "Get a sign-in link"

msgid "plugins.generic.magicLogin.request.hero"
msgstr "Sign in without a password"

msgid "plugins.generic.magicLogin.request.help"
msgstr "Enter your account email and we'll send you a one-time sign-in link. No password needed."

msgid "plugins.generic.magicLogin.request.emailPlaceholder"
msgstr "you@institution.edu"

msgid "plugins.generic.magicLogin.request.button"
msgstr "Email me a sign-in link"

msgid "plugins.generic.magicLogin.request.back"
msgstr "Back to sign in"

msgid "plugins.generic.magicLogin.login.button"
msgstr "Email me a sign-in link"

msgid "plugins.generic.magicLogin.request.sent"
msgstr "If that email matches an account, a sign-in link is on its way. Please check your inbox."

msgid "plugins.generic.magicLogin.request.sentNotice"
msgstr "The link expires in 15 minutes and works once only. Check your spam folder if it doesn't arrive."

# ── Confirm page (GET /magicLogin/confirm?token=…) ────────────────────────────
msgid "plugins.generic.magicLogin.confirm.title"
msgstr "Confirm sign-in"

msgid "plugins.generic.magicLogin.confirm.heading"
msgstr "You're signed in"

msgid "plugins.generic.magicLogin.confirm.section"
msgstr "Magic link received"

msgid "plugins.generic.magicLogin.confirm.hero"
msgstr "One click away"

msgid "plugins.generic.magicLogin.confirm.help"
msgstr "Click the button below to complete signing in to your account."

msgid "plugins.generic.magicLogin.confirm.button"
msgstr "Sign in now"

msgid "plugins.generic.magicLogin.confirm.back"
msgstr "Back to sign in"

msgid "plugins.generic.magicLogin.confirm.retry"
msgstr "Request a new link"

msgid "plugins.generic.magicLogin.confirm.invalidTitle"
msgstr "Link invalid"

msgid "plugins.generic.magicLogin.confirm.invalidHeading"
msgstr "This link has expired or been used"

# ── Error messages ─────────────────────────────────────────────────────────────
msgid "plugins.generic.magicLogin.error.invalid"
msgstr "This sign-in link is invalid or has already been used. Please request a new one."

msgid "plugins.generic.magicLogin.error.rateLimit"
msgstr "Too many sign-in attempts from your location. Please wait a few minutes and try again."

# ── Mailable (Settings › Emails) ──────────────────────────────────────────────
msgid "plugins.generic.magicLogin.mailable.link.name"
msgstr "Magic sign-in link"

msgid "plugins.generic.magicLogin.mailable.link.description"
msgstr "Sent when a user requests a one-time passwordless sign-in link. Customise the subject and body to match your journal's voice."

msgid "plugins.generic.magicLogin.mailable.link.subject"
msgstr "Your sign-in link for {$contextName}"

msgid "plugins.generic.magicLogin.mailable.link.body"
msgstr ""
"<p>Hi {$recipientName},</p>\n"
"<p>Use the link below to sign in to <strong>{$contextName}</strong>. "
"It expires in {$expiryMinutes} minutes and can only be used once.</p>\n"
"<p style=\"margin:28px 0;\">"
"<a href=\"{$magicUrl}\" style=\"background:#1a4a52;color:#ffffff;padding:12px 24px;"
"text-decoration:none;border-radius:2px;font-weight:600;\">Sign in to {$contextName}</a>"
"</p>\n"
"<p style=\"word-break:break-all;color:#666;font-size:13px;\">Or copy this link: {$magicUrl}</p>\n"
"<p>If you did not request this link, you can safely ignore this email — "
"your account has not been accessed.</p>"

# ── Mailable variable descriptions (shown in the email editor UI) ─────────────
msgid "plugins.generic.magicLogin.mailable.var.recipientName"
msgstr "The recipient's full name"

msgid "plugins.generic.magicLogin.mailable.var.magicUrl"
msgstr "The one-time sign-in URL (expires after {expiryMinutes} minutes)"

msgid "plugins.generic.magicLogin.mailable.var.expiryMinutes"
msgstr "Number of minutes until the link expires"
